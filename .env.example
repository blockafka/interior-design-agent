# ============ LLM (doubao via openai-next 兼容协议) ============
# 走 OpenAI 兼容 SDK 协议，doubao 多模态模型一站式覆盖视觉+文案
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai-next.com/v1
# 默认模型 doubao-seed-2-0-pro-260215 内置在 tools/llm.py

# ============ Cloudsway 三件套（采集 Agent 用） ============
CLOUDSWAY_API_KEY=
AGENT_API_KEY=
AGENT_API_BASE_URL=https://api.agentsway.dev

# ============ 文生图 ============
IMAGE_GEN_PROVIDER=mock
IMAGE_GEN_API_KEY=

# ============ 服务 ============
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=info
