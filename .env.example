# ============ Cloudsway 三件套 ============
CLOUDSWAY_API_KEY=
AGENT_API_KEY=
AGENT_API_BASE_URL=https://api.agentsway.dev

# ============ LLM（任选其一）============
# provider: mock / gemini / anthropic / openai / doubao
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DOUBAO_API_KEY=

# ============ Gemini (文本 + 文生图统一 key) ============
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-pro
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# ============ 文生图 ============
# provider: mock / gemini_image / sd_local / jimeng / dalle
IMAGE_GEN_PROVIDER=mock
IMAGE_GEN_API_KEY=

# ============ 服务 ============
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=info
